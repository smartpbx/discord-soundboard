# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here
PORT=3000

# Session secret (random string for signing cookies)
SESSION_SECRET=change-me-to-a-random-string

# Users: username:password:role (comma-separated). Roles: superadmin, admin, user
# - superadmin: can stop sounds for everyone, lock playback for everyone
# - admin: can stop/lock users only (not other admins)
# - user: can play sounds (max 7s), affected by admin lock
USERS=you:yourpass:superadmin,admin1:pass1:admin,admin2:pass2:admin,user1:pass1:user,user2:pass2:user

# Legacy (optional): single admin/user if USERS not set
# ADMIN_PASSWORD=your_admin_password
# USER_PASSWORD=your_user_password
# SUPERADMIN_PASSWORD=your_superadmin_password

# TTS service URL (optional, enables text-to-speech features)
# Point to your TTS server LXC/container running the Kokoro TTS service
# TTS_API_URL=http://10.x.x.x:8880

# Shared secret for TTS voice admin endpoints (PUT/DELETE /voices/chatterbox/...).
# Must match the TTS_ADMIN_TOKEN value in the TTS server's own .env. Without it,
# the superadmin "Add/Replace/Delete Chatterbox voice" UI returns 503.
# Generate with: openssl rand -hex 32
# TTS_ADMIN_TOKEN=

# Claude Code OAuth token for Phase 10 (auto voice training via Claude Code in
# headless mode). Generate on a machine with a browser logged into your Claude
# Pro/Max subscription:
#     claude setup-token
# Then paste the resulting token here. Token is long-lived (~1 year). Without
# it, the "+ Train new voice" button returns 503.
# CLAUDE_CODE_OAUTH_TOKEN=

# SSH host for the Phase 10 training pipeline (CT 110 / GPU container). Claude
# SSHes here to invoke the pipeline scripts. Default: root@10.10.10.72
# TTS_SSH_HOST=root@10.10.10.72

# Optional: override the claude binary path (default: claude on $PATH)
# CLAUDE_BIN=/usr/local/bin/claude
