# Discord Soundboard Companion — copy this to companion/.env and fill in values

# URL of your soundboard (local or via Cloudflare tunnel)
SOUNDBOARD_URL=http://localhost:3000

# Set this to the same value as COMPANION_TOKEN in your LXC .env
COMPANION_TOKEN=your_token_here

# Key bindings (keyboard library key names)
STOP_KEY=s
PAUSE_KEY=space
