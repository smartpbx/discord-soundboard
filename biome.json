{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": { "ignore": ["node_modules", "data", "sounds", "public/index.html", "package-lock.json"] },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 4, "lineWidth": 120 },
  "linter": { "enabled": true, "rules": { "recommended": true, "suspicious": { "noExplicitAny": "off" } } },
  "javascript": { "formatter": { "quoteStyle": "single", "semicolons": "always" } }
}
